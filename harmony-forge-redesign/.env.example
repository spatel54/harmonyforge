# Engine / Next API (existing)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000

# OpenAI (Theory Inspector) — copy to .env.local
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# M5 user study — RQ1 (generator vs reviewer arm)
# generator_primary | reviewer_primary
# NEXT_PUBLIC_HF_STUDY_CONDITION=generator_primary

# M5 user study — RQ2 (stylist suggestion prose)
# full | minimal  (minimal hides rationale/summary in API + panel)
# NEXT_PUBLIC_HF_SUGGESTION_EXPLANATION_MODE=full

# When true, show consent gate before using the app; participants can still continue without logging
# NEXT_PUBLIC_HF_STUDY_REQUIRES_CONSENT=false

# URL overrides (persisted to sessionStorage on first load):
# ?study=reviewer_primary
# ?hfExplain=minimal
