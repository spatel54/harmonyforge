{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LeadSheet",
  "description": "Input format for SATB generation",
  "type": "object",
  "required": ["key", "chords"],
  "properties": {
    "key": {
      "type": "object",
      "required": ["tonic", "mode"],
      "properties": {
        "tonic": {
          "type": "string",
          "enum": ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"]
        },
        "mode": {
          "type": "string",
          "enum": ["major", "minor"]
        }
      }
    },
    "chords": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["roman"],
        "properties": {
          "roman": { "type": "string" },
          "duration": { "type": "string" },
          "beat": { "type": "number" }
        }
      }
    },
    "melody": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pitch", "beat"],
        "properties": {
          "pitch": { "type": "string" },
          "beat": { "type": "number" }
        }
      }
    }
  }
}
