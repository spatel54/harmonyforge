# Theory Inspector (server-side API routes). Copy to `.env` or `.env.local`.
OPENAI_API_KEY=
# Optional: custom OpenAI-compatible API base (either name works). Use a single URL, e.g.:
# OPENAI_BASE_URL=https://openai.gateway.salt-lab.org/v1
OPENAI_BASE_URL=
OPENAI_URL=

# Optional model override (default: gpt-4o-mini)
OPENAI_MODEL=

# Engine URL for browser fetches (Playground preview, generate-from-file)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Abort generate-from-file after this many ms (default 180000). PDF/OMR can need headroom; engine file routes default ~108s solver cap unless HF_SOLVER_MAX_MS=0.
# NEXT_PUBLIC_GENERATE_TIMEOUT_MS=180000

# M5 study (optional) — see docs/plan.md
# NEXT_PUBLIC_HF_STUDY_CONDITION=
# NEXT_PUBLIC_HF_SUGGESTION_EXPLANATION_MODE=
# NEXT_PUBLIC_HF_STUDY_REQUIRES_CONSENT=
