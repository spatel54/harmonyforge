# Copy to .env.local in this folder. Never commit .env.local.

# Live Theory Inspector (chat, stylist suggest). Omit for offline taxonomy fallback.
OPENAI_API_KEY=

# Optional — only if you use a non-default OpenAI-compatible endpoint (e.g. Azure proxy).
# Leave unset for api.openai.com; you do not need a base URL for a normal OpenAI key.
# OPENAI_BASE_URL=
# OPENAI_URL=
