# Copy to `.env.local` in this folder. Never commit `.env.local`.
# Used server-side only: Theory Inspector (`/api/theory-inspector`, `/api/theory-inspector/suggest`).
# Reference: https://platform.openai.com/docs/api-reference

# --- API key (required for a live LLM) ---
# OpenAI API key, or the Bearer token your gateway expects.
OPENAI_API_KEY=

# --- API base URL (optional) ---
# OpenAI-compatible API root. When unset, the SDK uses the default OpenAI host (see LangChain / OpenAI client).
# Include the path your provider requires (often `.../v1`). Trailing slashes are trimmed in code.
#
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT/v1
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
#
# Legacy alias (same as OPENAI_BASE_URL):
# OPENAI_URL=

# --- Chat model id (optional) ---
# Passed to Chat Completions as the model / deployment name. When unset, the app defaults to the
# lowest-cost standard chat model on OpenAI’s published pricing table (`gpt-5-nano` as of 2026; see
# https://platform.openai.com/docs/pricing ). Override if your org or gateway does not expose that id yet.
#
# Rough tiers (examples only — check your provider’s catalog):
#   Lowest cost:  gpt-5-nano (default), gpt-4.1-nano, gpt-4o-mini
#   Balanced:     gpt-5-mini, gpt-5.4-nano, gpt-4.1-mini
#   Higher:       gpt-5.4-mini, gpt-4o, gpt-5.4
#   Reasoning:    o4-mini, o3, … (different latency and billing)
#
OPENAI_MODEL=gpt-5-nano
