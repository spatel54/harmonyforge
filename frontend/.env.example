# HarmonyForge — Next.js loads env from this directory. Copy to `frontend/.env.local`.
# Never commit `.env.local`.
#
# Typical local setup: only an API key and a model name (see `src/lib/ai/llmClient.ts`).
# You do not need the optional block below unless you use a custom OpenAI-compatible endpoint.

# --- Required for Theory Inspector / LLM routes (when not in offline mode) ---
# Must be your sk-… secret from OpenAI — NOT the model name. Put gpt-4o-mini (etc.) only in OPENAI_MODEL.
OPENAI_API_KEY=

# --- Model (optional; falls back in code to gpt-5-nano if unset) ---
OPENAI_MODEL=gpt-5-nano

# --- Optional: OpenAI-compatible base URL (e.g. Azure, local proxy) ---
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_URL=