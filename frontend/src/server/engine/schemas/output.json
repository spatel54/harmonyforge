{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SATBGenerationResponse",
  "description": "Output format for SATB generation",
  "type": "object",
  "required": ["slots"],
  "properties": {
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chord", "voices"],
        "properties": {
          "chord": {
            "type": "object",
            "required": ["roman"],
            "properties": {
              "roman": { "type": "string" },
              "duration": { "type": "string" },
              "beat": { "type": "number" }
            }
          },
          "voices": {
            "type": "object",
            "required": ["soprano", "alto", "tenor", "bass"],
            "properties": {
              "soprano": { "type": "string" },
              "alto": { "type": "string" },
              "tenor": { "type": "string" },
              "bass": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
