# HarmonyForge reads env from `frontend/` (Next.js). Copy this file to:
#   frontend/.env.local
# Never commit `.env.local`.
#
# Full comments and model tiers: see frontend/.env.example

# --- API key ---
OPENAI_API_KEY=

# --- OpenAI-compatible base URL (optional) ---
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_URL=

# --- Chat model (optional; code default: gpt-5-nano — see frontend/.env.example) ---
OPENAI_MODEL=gpt-5-nano