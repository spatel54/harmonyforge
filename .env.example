# HarmonyForge — Environment Variables
# Copy to .env.local and fill in values before running locally or in Docker.
# Never commit .env.local to git.

# ── Frontend (Next.js) ─────────────────────────────────────────────────────────

# Public URL of the Express backend (port 8000).
# Used in client-side fetch calls (baked into the Next.js bundle at build time).
# Local:         http://localhost:8000
# DO App Platform: set automatically via ${backend.PUBLIC_URL} in .do/app.yaml
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: separate engine URL override. Falls back to NEXT_PUBLIC_API_URL.
# NEXT_PUBLIC_ENGINE_URL=

# OpenAI API key for the Theory Inspector LLM sidebar.
# Required for /api/theory-inspector routes. Never exposed to the browser.
OPENAI_API_KEY=...

# Optional: OpenAI model override. Defaults to gpt-4o-mini.
# OPENAI_MODEL=gpt-4o-mini

# Optional: custom OpenAI base URL (e.g. Azure OpenAI, LiteLLM proxy).
# OPENAI_BASE_URL=
# OPENAI_URL=

# ── Backend (Express, port 8000) ───────────────────────────────────────────────

# Allowed CORS origin. Must match the frontend's public URL.
# Local:         http://localhost:3000
# DO App Platform: set automatically via ${APP_URL} in .do/app.yaml
CORS_ORIGIN=...

# ── Study mode (optional) ─────────────────────────────────────────────────────

# Set to "true" to gate access behind a consent screen.
# NEXT_PUBLIC_HF_STUDY_REQUIRES_CONSENT=false

# Study condition label (e.g. "glass-box", "black-box").
# NEXT_PUBLIC_HF_STUDY_CONDITION=

# Explanation mode ("inline" | "sidebar").
# NEXT_PUBLIC_HF_SUGGESTION_EXPLANATION_MODE=
