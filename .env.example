# Convenience copy at repo root — authoritative template: `frontend/.env.example`
#
# Next.js loads env from `frontend/`. Copy that file to:
#   frontend/.env.local
# Never commit `.env.local`.
#
# Typical local setup: only `OPENAI_API_KEY` and `OPENAI_MODEL` in `frontend/.env.local`.

# --- API key + model (same names as `frontend/.env.example`) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano