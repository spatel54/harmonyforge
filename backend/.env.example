# HarmonyForge engine (Express). Copy to `.env` if your runner loads dotenv.

# CORS: exact frontend origin (no path)
# CORS_ORIGIN=http://localhost:3000

# HTTP port (platforms often set PORT)
# PORT=8000

# Long scores: cap inferred chord slots (default 128)
# HF_MAX_CHORD_SLOTS=128

# SATB solver safety (defaults: 3M nodes)
# HF_SOLVER_MAX_NODES=3000000
# Wall clock: unset → generate-from-file / validate-from-file default ~108s (422 before typical browser abort).
# Set to 0 for no limit on those routes. POST /api/generate-satb still uses HF_SOLVER_MAX_MS only when set (default no cap).
# HF_SOLVER_MAX_MS=0

# HF_SOLVER_MODE: auto (greedy first, then backtrack) | greedy | backtrack | exact
# HF_SOLVER_MODE=auto
# Reserved for future tuning (not used to gate greedy today):
# HF_GREEDY_THRESHOLD=56

# PDF / OMR (optional)
# PDFALTO_BIN=
# POPPLER_PDFTOPPM=
# OEMER_BIN=
